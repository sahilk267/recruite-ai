# ─── Required ─────────────────────────────────────────────────────────────────

# JWT signing key — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-before-deploy

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# Default: http://localhost:5173,http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# ─── Email (Hostinger SMTP) — Phase 5 ────────────────────────────────────────

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@overseasjob.in
SMTP_PASSWORD=your-smtp-password-here

# ─── Gemini AI (auto-set by Replit AI Integration — do NOT set manually) ─────

# AI_INTEGRATIONS_GEMINI_API_KEY=managed-by-replit
# AI_INTEGRATIONS_GEMINI_BASE_URL=managed-by-replit

# ─── Database ─────────────────────────────────────────────────────────────────

# SQLite (default) — change to PostgreSQL URL for production
# DATABASE_URL=postgresql://user:password@localhost/recruiteai
